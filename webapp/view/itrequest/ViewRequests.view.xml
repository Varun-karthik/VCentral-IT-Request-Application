<mvc:View xmlns:core="sap.ui.core" controllerName="vcentral.controller.itrequest.ViewRequests"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page title="My Requests" showNavButton="true" navButtonPress="back" >
    <FlexBox direction="Column" class="sapUiSmallMargin">  
    <Table id="Requests_table" items="{RequestModel>/itrequestSet}">
        <headerToolbar>
            <OverflowToolbar >
                <Title text="My Requests"></Title>
                <ToolbarSpacer ></ToolbarSpacer>
                <ComboBox selectedKey="allStatus" selectionChange="onStatusChange">
                <core:Item key="allStatus" text="All Status" ></core:Item>
                <core:Item key="Open" text="Open"></core:Item>
                <core:Item key="In Progress" text="In Progress"></core:Item>
                <core:Item key="Closed" text="Closed"></core:Item>
                </ComboBox>
                <Button icon="sap-icon://download" press="download"></Button>
                <Title id="count" text="10 of 16 requests" ></Title>
            </OverflowToolbar>
        </headerToolbar>
        <!-- Columns -->
        <columns >
        <Column><Text text="ID" /></Column>
        <Column><Text text="Category" /></Column>
        <Column><Text text="Priority" /></Column>
        <Column><Text text="Status" /></Column>
        <Column><Text text="Created On" /></Column>
        <Column><Text text="Actions" /></Column>
        </columns>
        <items>
        <ColumnListItem type="Active">
        <cells>
        <Text text="{RequestModel>RequestId}"></Text>
        <Text text="{RequestModel>Category}"></Text>
        <Text text="{RequestModel>Priority}"></Text>
        <Text text="{RequestModel>Status}"></Text>
        <Text text="{path: 'RequestModel>CreatedOn', 
                    formatter: 'formatter.formatDate'}" >
                    </Text>
        <HBox gap="5px" >
        <Button icon="sap-icon://edit" type="Transparent" press="requestdetails"></Button>
        <Button icon="sap-icon://delete" type="Transparent" press="requestdetails"></Button>
        </HBox>
        </cells>
        </ColumnListItem>
        </items>
    </Table>

    </FlexBox>
    </Page>
</mvc:View>